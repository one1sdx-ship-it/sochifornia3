# Пример переменных окружения. Скопируйте в .env и заполните своими значениями.

# Подключение к PostgreSQL.
# Локально (dev): ваш Postgres на ПК.
# Прод (Vercel): строка от бесплатного облачного Postgres (Neon / Vercel Postgres).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sochifornia?schema=public"

# Секрет сессий Auth.js. Сгенерировать: npx auth secret  (или любой длинный рандом).
AUTH_SECRET=""

# Google OAuth (для входа через Google). Заполнить на этапе 2.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Vercel Blob (загрузка фото). Заполнить на этапе 5.
BLOB_READ_WRITE_TOKEN=""

# ── Онлайн-чат ──
# Telegram-бот (создать в @BotFather: /newbot → токен сюда).
TELEGRAM_BOT_TOKEN=""
# Имя бота БЕЗ @ (для ссылок t.me/<бот>?start=...).
NEXT_PUBLIC_TG_BOT_USERNAME=""
# Случайная строка — защита webhook (та же передаётся в setWebhook).
TELEGRAM_WEBHOOK_SECRET=""
# Web Push (VAPID): сгенерировать один раз
#   node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
