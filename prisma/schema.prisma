// Схема базы данных sochifornia (Prisma + PostgreSQL).
// Модель контента экскурсий + пользователи/роли + сессии + журнал изменений.
// Комментарии на русском по договорённости проекта.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Пользователи, роли, аутентификация (Auth.js Prisma adapter)
// ─────────────────────────────────────────────────────────────

enum Role {
  ADMIN // полный доступ
  EDITOR // может только создавать черновики, чужое не трогает
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String? // для входа по email+паролю (null у Google-аккаунтов)
  role          Role      @default(EDITOR)
  sessionVersion Int      @default(0) // ++ при «выходе со всех устройств» — старые токены становятся невалидны
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[] // хранение сессий в БД => «выход со всех устройств» = удалить все

  // Связи для журнала и авторства
  createdTours Tour[]     @relation("TourCreatedBy")
  updatedTours Tour[]     @relation("TourUpdatedBy")
  auditLogs    AuditLog[]

  // ── Чат с клиентами ──
  chatDisplayName String  @default("") // имя, которое видит клиент в чате (задаёт сам сотрудник)
  chatAvatarUrl   String  @default("") // аватар сотрудника в чате
  telegramChatId  String? // личный TG-чат сотрудника с ботом (для уведомлений о новых сообщениях)
  tgLinkToken     String? @unique // токен deep-link'а t.me/бот?start=emp_<token> (создаётся лениво в коде)
  chatMessages    ChatMessage[]
}

// Таблицы адаптера Auth.js (для входа через Google и хранения сессий)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Экскурсии (контент)
// ─────────────────────────────────────────────────────────────

enum TourStatus {
  DRAFT // черновик, на сайте не виден
  PUBLISHED // опубликован
  ARCHIVED // в архиве (раздел «Архив»)
}

enum TourCategory {
  mountains
  sea
  city
  nature
  kids
  vip
}

enum TourFormat {
  group
  individual
}

model Tour {
  id      String       @id @default(cuid())
  slug    String       @unique
  status  TourStatus   @default(DRAFT)
  title   String
  excerpt String       @default("")
  category TourCategory @default(city)
  format  TourFormat   @default(group)

  // Стоимость
  adultPrice Int    @default(0) // цена за взрослого, ₽/чел
  childPrice Int    @default(0) // цена за ребёнка, ₽/чел
  priceSuffix String @default("₽/чел") // приписка/валюта

  // Прочие параметры карточки
  durationHours Int      @default(0)
  startTime     String   @default("")
  rating        Float    @default(5)
  reviewsCount  Int      @default(0)
  seasonal      Boolean  @default(false)
  vip           Boolean  @default(false)
  image         String   @default("") // обложка (id-градиент или url)

  sortOrder Int @default(0) // порядок в списках

  // «Место встречи» (бывший раздел «Маршрут» на странице тура) + гео для отправки картой в чат
  meetingAddress String @default("") // человекочитаемый адрес точки сбора
  meetingLat     Float? // широта
  meetingLng     Float? // долгота

  // Аудит/авторство
  createdById String?
  updatedById String?
  createdBy   User?   @relation("TourCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?   @relation("TourUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  publishedAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Вложенный контент
  gallery      TourImage[] // карусель фото (одна на страницу и блок — синхронно)
  blocks       TourBlock[] // 4 блока под каруселью (иконка + заголовок)
  program      ProgramPoint[] // «Программа экскурсии» (точки: время/заголовок/описание)
  listItems    TourListItem[] // «что входит / не входит / что взять»
  extraTariffs ExtraTariff[] // доп. тарифы (пенсионеры, группа и т.п.)

  auditLogs AuditLog[]

  @@index([status])
  @@index([category])
}

// Фото галереи/карусели (порядок задаёт карусель и блок синхронно)
model TourImage {
  id     String @id @default(cuid())
  tourId String
  tour   Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  url    String
  alt    String @default("")
  order  Int    @default(0)

  @@index([tourId])
}

enum IconType {
  LUCIDE // иконка из набора lucide-react (по имени)
  CUSTOM // загруженный свой файл (url)
}

// 4 блока под каруселью: иконка + заголовок (только заголовок, без подписи)
model TourBlock {
  id       String   @id @default(cuid())
  tourId   String
  tour     Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  icon     String   @default("") // имя lucide-иконки ИЛИ url своего файла
  iconType IconType @default(LUCIDE)
  title    String   @default("")
  order    Int      @default(0)

  @@index([tourId])
}

// Точка «Программы экскурсии»
model ProgramPoint {
  id     String @id @default(cuid())
  tourId String
  tour   Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  time   String @default("") // время пункта
  title  String @default("") // заголовок пункта
  text   String @default("") // описание пункта
  order  Int    @default(0)

  @@index([tourId])
}

enum ListKind {
  INCLUDED // что входит
  EXCLUDED // не входит
  BRING // что взять с собой
}

// Пункт списков «что входит / не входит / что взять»
model TourListItem {
  id       String   @id @default(cuid())
  tourId   String
  tour     Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  kind     ListKind
  text     String   @default("")
  icon     String? // для «что взять» — своя иконка слева (иначе галочка по умолчанию)
  iconType IconType @default(LUCIDE)
  order    Int      @default(0)

  @@index([tourId, kind])
}

// Доп. тарифы (пенсионеры, группа и т.п.)
model ExtraTariff {
  id     String @id @default(cuid())
  tourId String
  tour   Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)
  label  String @default("")
  price  Int    @default(0)
  order  Int    @default(0)

  @@index([tourId])
}

// ─────────────────────────────────────────────────────────────
// Журнал изменений (кто / что / когда)
// ─────────────────────────────────────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  PUBLISH
  ARCHIVE
  RESTORE
  COPY
  DELETE
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  tourId    String?
  tour      Tour?       @relation(fields: [tourId], references: [id], onDelete: SetNull)
  tourTitle String      @default("") // копия названия на момент действия (переживает удаление)
  summary   String      @default("") // человекочитаемое описание
  meta      Json? // детали (какие поля менялись и т.п.) — задел на откат версий
  createdAt DateTime    @default(now())

  @@index([tourId])
  @@index([userId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────
// Онлайн-чат с клиентами (виджет на сайте + /admin/chats + TG-бот)
// ─────────────────────────────────────────────────────────────

// Кто написал сообщение.
enum ChatSender {
  CLIENT // посетитель сайта
  STAFF // сотрудник (из админки)
  BOT // автоответы/приветствия/промокод
}

// Тип содержимого сообщения.
enum ChatMsgType {
  TEXT // обычный текст
  IMAGE // фото (attachmentUrl)
  VOICE // голосовое (attachmentUrl)
  TOUR_CARD // карточка экскурсии (meta: slug/title/price/image)
  LOCATION // точка на карте (meta: lat/lng/label)
  PROMO // промокод −5% (text = код)
  SYSTEM // служебное (вопрос про Telegram при отсутствии и т.п.)
}

// Диалог: один на анонимного клиента (ID хранится у него в localStorage).
// История ОБЩАЯ: все сотрудники видят один и тот же диалог с клиентом.
model ChatConversation {
  id       String @id @default(cuid())
  clientId String @unique // анонимный ID из localStorage клиента

  clientName  String @default("") // имя из формы (необязательное)
  clientPhone String @default("") // телефон из формы (обязательный, E.164)

  currentTourSlug String @default("") // с какой страницы тура открыт чат (контекст для сотрудника)

  // «Продолжить в Telegram»: токен для deep-link t.me/бот?start=c_<token>;
  // после /start клиента сюда пишется его TG-чат — ответы дублируются в Telegram.
  tgLinkToken      String  @unique @default(cuid())
  clientTelegramId String? // TG-чат клиента (null — не подключал)

  // Промокод −5% (падает в чат через N минут после вопроса без брони).
  promoCode   String    @default("")
  promoSentAt DateTime?

  // Присутствие и индикаторы.
  lastClientSeenAt DateTime  @default(now()) // последний поллинг виджета (для «клиент ушёл >5 мин»)
  lastOpenAt       DateTime? // последний поллинг с ОТКРЫТЫМ окном чата (для push: окно закрыто → шлём push)
  clientTypingAt   DateTime? // клиент печатает (свежее 4с = печатает)
  staffTypingAt    DateTime? // сотрудник печатает
  staffTypingName  String    @default("") // имя печатающего сотрудника

  absenceAskedAt DateTime? // задан ли уже вопрос «связаться в Telegram, если вас нет?»

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages    ChatMessage[]
  viewedTours ChatViewedTour[]
  pushSubs    ChatPushSub[]

  @@index([updatedAt])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  sender ChatSender
  type   ChatMsgType @default(TEXT)

  // Автор-сотрудник (для STAFF): имя/аватар клиент видит в шапке и у пузыря.
  authorId String?
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  text          String @default("") // текст / код промо / подпись
  attachmentUrl String @default("") // фото или голосовое (Vercel Blob / /uploads)
  meta          Json? // TOUR_CARD: {slug,title,price,image,duration}; LOCATION: {lat,lng,label}

  // Статусы: «доставлено» = запись создана; «прочитано» = противоположная сторона открыла чат.
  readByClient Boolean @default(false)
  readByStaff  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

// Экскурсии, которые клиент просматривал (сотрудник видит контекст интересов).
model ChatViewedTour {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  slug           String
  title          String   @default("")
  viewedAt       DateTime @default(now())

  @@unique([conversationId, slug])
  @@index([conversationId])
}

// Подписка на браузерные push-уведомления (Web Push, VAPID).
model ChatPushSub {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  endpoint       String   @unique
  p256dh         String
  auth           String
  createdAt      DateTime @default(now())

  @@index([conversationId])
}
